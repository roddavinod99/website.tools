# =============================================================================
# DevStackIO Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- Site Configuration ---
# Canonical site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://tools.devstackio.com

# Contact email displayed on the contact page
NEXT_PUBLIC_CONTACT_EMAIL=contact@devstackio.com

# --- Analytics & Ads ---
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# Leave empty to disable analytics
NEXT_PUBLIC_GA_ID=

# Google AdSense Publisher ID (e.g. ca-pub-XXXXXXXXXXXXXXXX)
# Leave empty to disable ads
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=

# --- Server Configuration ---
# Server port (default: 3000)
PORT=3000

# --- Rate Limiting ---
# Set to 'true' when behind a reverse proxy with its own rate limiting
# WARNING: Disabling rate limiting removes application-level DoS protection
# DISABLE_RATE_LIMIT=true

# --- IndexNow ---
# IndexNow API key for Bing/Yandex/Seznam sitemap submission
# INDEXNOW_KEY=

# --- Security ---
# Salt used for hashing IP addresses in security logging.
# REQUIRED IN PRODUCTION. The build will fail if this is not set in production.
# Generate with: openssl rand -hex 32
# Example: IP_HASH_SALT=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6
IP_HASH_SALT=

# If your reverse proxy (Nginx) handles rate limiting, set to 'true' to disable
# application-level rate limiting.
# DISABLE_RATE_LIMIT=true

# --- IndexNow Key File ---
# Create public/{key}.txt with the key value for IndexNow verification
